# 复制此文件为 .env 并填写真实值
# cp .env.example .env

# ──────────────────────────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────────────────────────

# 根据 CPU 架构选择，取消注释对应行
#   arm64 : Apple Silicon / ARM 服务器
#   x64   : Intel / AMD 服务器（含 TimescaleDB + PostGIS + HA）

POSTGRES_IMAGE=postgis/postgis:16-3.4-alpine
# POSTGRES_IMAGE=timescale/timescaledb-ha:pg16

# ──────────────────────────────────────────────────────────────
# 统一密码
# ──────────────────────────────────────────────────────────────

POSTGRES_PASSWORD=changeme
REDIS_PASSWORD=changeme
S3_ACCESS_KEY=zynex
S3_SECRET_KEY=changeme

# ──────────────────────────────────────────────────────────────
# SeaweedFS (S3)
# ──────────────────────────────────────────────────────────────

S3_ENDPOINT=http://localhost:8333
S3_BUCKET=zyn
